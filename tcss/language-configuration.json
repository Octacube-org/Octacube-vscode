{
  "comments": {
    "lineComment": {"comment":"//"},
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["\"", "\""],
    { "open": "/*", "close": "*/", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "@<", "close": ">" },
    ["@<", ">"],
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["/*", "*/"],
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\<\\>\\/\\?\\s]+)",
  "folding": {
    // from https://github.com/vshaxe/vshaxe/blob/master/configurations/haxe.language-configuration.json
		"markers": {
			"start": "^\\s*\\\/[\\\/\\*]\\s*[#{]?\\s*region\\b",
			"end": "^\\s*\\\/[\\\/\\*]\\s*[#}]?\\s*end ?region\\b"
		}
	},
}